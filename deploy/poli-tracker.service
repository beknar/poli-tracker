[Unit]
Description=poli-tracker (gunicorn behind nginx)
After=network-online.target
Wants=network-online.target

[Service]
WorkingDirectory=/opt/poli-tracker
Environment=CT_MAX_TICKERS=40
# Bind to localhost only; nginx terminates TLS on 443 and proxies here.
ExecStart=/opt/poli-tracker/.venv/bin/gunicorn -b 127.0.0.1:8000 -w 1 --timeout 120 app:app
Restart=always

[Install]
WantedBy=multi-user.target
